@page "/"
@using SSJ_Portal_v2.Models

<PageTitle>หน้าหลัก | SSJ Portal</PageTitle>

<div class="min-h-screen bg-slate-50 py-10 px-4">
    <div class="max-w-7xl mx-auto">
        
        @* --- ส่วนหัวข้อของหน้าเว็บ --- *@
        <header class="text-center mb-16">
            <h1 class="text-3xl md:text-4xl font-bold text-slate-800 mb-3">
                ระบบบริการสารสนเทศภายใน
            </h1>
            <p class="text-slate-500 font-medium">
                สำนักงานสาธารณสุขจังหวัดนครศรีธรรมราช (Nakhon Si Thammarat PH)
            </p>
        </header>

        @* --- ส่วนการแสดงผลรายการบริการ (Grid) --- *@
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @if (_services != null)
            {
                @foreach (var service in _services)
                {
                    <div class="group relative transition-all duration-300 hover:-translate-y-2">
                        @* Glassmorphism Card Container *@
                        <div class="bg-white/80 backdrop-blur-md border border-white p-2 rounded-[2rem] shadow-sm group-hover:shadow-xl transition-shadow">
                            
                            @* Icon Container with Dynamic Gradient *@
                            <div class="bg-gradient-to-br @service.GradientStyle h-36 rounded-3xl flex items-center justify-center relative shadow-inner">
                                <i class="@service.IconClass text-5xl text-white drop-shadow-lg"></i>
                                
                                @* Status Badge *@
                                <div class="absolute top-4 right-4 shadow-lg">
                                    @renderStatusBadge(service.Status)
                                </div>
                            </div>

                            @* Service Details *@
                            <div class="p-6 text-center">
                                <h2 class="text-xl font-bold text-slate-800 mb-2">@service.Title</h2>
                                <p class="text-sm text-slate-400 mb-6 h-10 overflow-hidden line-clamp-2">
                                    @service.Description
                                </p>
                                
                                <a href="@service.TargetUrl" 
                                   class="block w-full py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl transition-all active:scale-95 shadow-md shadow-blue-100">
                                    เข้าใช้งาน
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private List<ServiceItem>? _services;

    protected override void OnInitialized()
    {
        LoadMockData();
    }

    /// <summary>
    /// จำลองการดึงข้อมูลบริการ (ในอนาคตจะเปลี่ยนเป็นการดึงจาก Database)
    /// </summary>
    private void LoadMockData()
    {
        _services = new List<ServiceItem>
        {
            new() { 
                Title = "Project Plan", 
                Description = "ติดตามสถานะโครงการและแผนงานสาธารณสุข", 
                IconClass = "fa-solid fa-diagram-project", 
                GradientStyle = "from-amber-400 to-yellow-300",
                Status = ServiceStatus.Online
            },
            new() { 
                Title = "Dental System", 
                Description = "ระบบรายงานข้อมูลทางทันตกรรมระดับจังหวัด", 
                IconClass = "fa-solid fa-tooth", 
                GradientStyle = "from-emerald-400 to-teal-300",
                Status = ServiceStatus.Online
            },
            new() { 
                Title = "IT Helpdesk", 
                Description = "แจ้งซ่อมบำรุงคอมพิวเตอร์และระบบเครือข่าย", 
                IconClass = "fa-solid fa-headset", 
                GradientStyle = "from-rose-400 to-orange-300",
                Status = ServiceStatus.Online
            },
            new() { 
                Title = "Meeting Room", 
                Description = "จองห้องประชุมและตรวจสอบตารางการใช้งานประจำวัน", 
                IconClass = "fa-solid fa-calendar-days", 
                GradientStyle = "from-indigo-500 to-purple-400",
                Status = ServiceStatus.Maintenance
            }
        };
    }

    /// <summary>
    /// Render Status Badge ตามสถานะที่กำหนด
    /// </summary>
    private RenderFragment renderStatusBadge(ServiceStatus status) => __builder =>
    {
        var (color, icon) = status switch
        {
            ServiceStatus.Online => ("bg-green-500", "fa-check"),
            ServiceStatus.Maintenance => ("bg-orange-500", "fa-screwdriver-wrench"),
            _ => ("bg-gray-400", "fa-question")
        };

        <div class="flex items-center justify-center h-8 w-8 rounded-full border-2 border-white @color shadow-sm">
            <i class="fa-solid @icon text-[12px] text-white"></i>
        </div>
    };
}