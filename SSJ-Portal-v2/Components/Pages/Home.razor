@page "/"
@using SSJ_Portal_v2.Models
@rendermode InteractiveServer

<PageTitle>หน้าหลัก | SSJ Portal</PageTitle>
@*
<div class="glass-card shadow-2xl" 
     style="position: fixed; top: 250px; left: 50%; transform: translateX(-50%); 
            width: 320px; height: 200px; z-index: 9999; 
            display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem;">
    
    <div class="bg-blue-500 w-12 h-12 rounded-full mb-3 flex items-center justify-center">
        <i class="fa-solid fa-flask text-white text-xl"></i>
    </div>
    
    <div class="text-slate-800 font-bold text-lg">
        Class .glass-card Test
    </div>
    
    <p class="text-slate-500 text-xs text-center mt-2">
        ถ้าคุณเห็นพื้นหลังข้างหลัง "เบลอ" <br/> 
        แสดงว่า CSS ของเราถูกต้อง 100% ครับ!
    </p>
</div>*@

@* --- ส่วน Banner ต้อนรับ --- *@
<div class="w-full bg-gradient-to-r from-blue-600 to-teal-400 py-16 px-4 rounded-[2.5rem] shadow-xl shadow-inner">
    <div class="max-w-7xl mx-auto text-center text-white">
        <h1 class="text-3xl md:text-4xl font-bold mb-4 drop-shadow-md">
            ยินดีต้อนรับ เข้าสู่ระบบบริการสารสนเทศภายใน
        </h1>
        <p class="text-lg opacity-90 font-medium">
            สำนักงานสาธารณสุขจังหวัดนครศรีธรรมราช
        </p>
        <p class="text-sm opacity-75 mt-2 italic">
            "เข้าถึงบริการและระบบงานต่าง ๆ ขององค์กรได้ในที่เดียว"
        </p>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 pb-20">
    
    @* --- ส่วนค้นหาบริการ --- *@
    <div class="flex justify-center -translate-y-1/2 mb-16 relative z-10">
        <div class="relative w-full max-w-xl group">
            <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
                <i
                class="fa-solid fa-magnifying-glass text-blue-500 group-focus-within:scale-110 transition-transform"></i>
            </div>
            @* @bind:event="oninput" ช่วยให้การค้นหาเป็นแบบ Real-time ทันทีที่พิมพ์ *@
            <input type="text" value="@_searchTerm" @oninput="(e) => _searchTerm = e.Value?.ToString() ?? string.Empty"
                   placeholder="ค้นหาบริการ..."
                   class="block w-full pl-14 pr-6 py-3 bg-white border-none rounded-full shadow-[0_15px_40px_rgba(0,0,0,0.1)] focus:ring-4 focus:ring-blue-100 outline-none text-slate-700 text-lg transition-all" />
        </div>
    </div>

    @* --- ส่วนแสดงผลรายการบริการ --- *@
    @* --- Service Grid --- *@
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 items-stretch">
        @foreach (var service in FilteredServices)
        {
            <div class="group h-full transition-all duration-300 hover:-translate-y-2">
                <div class="glass-card p-6 flex flex-col h-full cursor-pointer">
                    <div
                        class="bg-gradient-to-br @service.GradientStyle h-36 rounded-3xl flex-shrink-0 flex items-center justify-center relative shadow-inner">
                        <i class="@service.IconClass text-5xl text-white drop-shadow-lg"></i>
                        <div class="absolute top-4 right-4">
                            @RenderStatusBadge(service.Status)
                        </div>
                    </div>
                    <div class="p-6 text-center flex flex-col flex-grow">
                        <h2 class="text-xl font-bold text-slate-800 mb-2">@service.Title</h2>
                        <p class="text-sm text-slate-400 mb-6 line-clamp-2 flex-grow">
                            @service.Description
                        </p>
                        <a href="@service.TargetUrl"
                               class="mt-auto w-full py-3 bg-gradient-to-r from-blue-600 to-teal-400 hover:brightness-110 hover:shadow-lg hover:shadow-blue-500/40 text-white font-bold rounded-xl flex items-center justify-center gap-3 transition-all active:scale-95 shadow-md shadow-blue-500/20 group">
    
                            @* ข้อความปุ่ม *@
                            <span>เข้าใช้งาน</span>
    
                            @* ไอคอนลูกศรชี้ขวา (Arrow Right) ตามตัวอย่าง *@
                            @* transition-transform และ group-hover จะทำให้ลูกศรขยับนิดหน่อยตอนเอาเมาส์ชี้ *@
                            <i class="fa-solid fa-arrow-right text-lg transition-transform group-hover:translate-x-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @* --- กรณีไม่พบข้อมูล --- *@
    @if (!FilteredServices.Any())
    {
        <div class="text-center py-20 text-slate-400">
            <i class="fa-solid fa-box-open text-5xl mb-4 opacity-20"></i>
            <p class="text-lg">ไม่พบบริการที่คุณกำลังค้นหา</p>
        </div>
    }
</div>

@code {
    /// <summary>
    /// คำค้นหาที่ผู้ใช้พิมพ์ในช่อง Search
    /// </summary>
    private string _searchTerm = string.Empty;

    /// <summary>
    /// รายการบริการทั้งหมดที่มีในระบบ
    /// </summary>
    private List<ServiceItem> _services = new();

    /// <summary>
    /// รายการบริการที่ผ่านการกรองตามคำค้นหา (Filtered List)
    /// </summary>
    private IEnumerable<ServiceItem> FilteredServices =>
    (_services ?? new List<ServiceItem>())
    .Where(s => string.IsNullOrWhiteSpace(_searchTerm) ||
                s.Title.Contains(_searchTerm, StringComparison.CurrentCultureIgnoreCase) ||
                s.Description.Contains(_searchTerm, StringComparison.CurrentCultureIgnoreCase));

    protected override void OnInitialized()
    {
        LoadMockData();
    }

    /// <summary>
    /// จำลองการโหลดข้อมูลบริการ
    /// </summary>
    private void LoadMockData()
    {
        _services = new List<ServiceItem>
        {
            new() {
                Title = "Project Plan",
                Description = "จัดการแผนงานและติดตามสถานะโครงการต่างๆ ของหน่วยงาน",
                IconClass = "fa-solid fa-diagram-project",
                GradientStyle = "from-amber-400 to-yellow-300",
                Status = ServiceStatus.Online
            },
            new() {
                Title = "Dental System",
                Description = "ระบบรายงานข้อมูลทางทันตกรรมระดับจังหวัด",
                IconClass = "fa-solid fa-tooth",
                GradientStyle = "from-emerald-400 to-teal-300",
                Status = ServiceStatus.Online
            },
            new() {
                Title = "IT Helpdesk",
                Description = "แจ้งซ่อมบำรุงคอมพิวเตอร์และระบบเครือข่าย",
                IconClass = "fa-solid fa-headset",
                GradientStyle = "from-rose-400 to-orange-300",
                Status = ServiceStatus.Online
            },
            new() {
                Title = "Meeting Room",
                Description = "จองห้องประชุมและตรวจสอบตารางการใช้งานประจำวัน",
                IconClass = "fa-solid fa-calendar-days",
                GradientStyle = "from-indigo-500 to-purple-400",
                Status = ServiceStatus.Maintenance
            }
        };
    }

    /// <summary>
    /// วาด UI ของ Status Badge ตามสถานะที่ระบุ
    /// </summary>
    /// <param name="status">สถานะของบริการ</param>
    private RenderFragment RenderStatusBadge(ServiceStatus status) => __builder =>
    {
        // กำหนดสีและไอคอนตามสถานะโดยใช้ Switch Expression (C# 8.0+)
        var (color, icon) = status switch
        {
            ServiceStatus.Online => ("bg-green-500", "fa-check"),
            ServiceStatus.Maintenance => ("bg-orange-500", "fa-screwdriver-wrench"),
            _ => ("bg-slate-400", "fa-question")
        };

        <div class="flex items-center justify-center h-8 w-8 rounded-full border-2 border-white @color shadow-md">
            <i class="fa-solid @icon text-[12px] text-white"></i>
        </div>
    };
}