    /// <summary>
    /// วาด UI ของ Status Badge ตามสถานะที่ระบุ
    /// </summary>
    /// <param name="status">สถานะของบริการ</param>
    private RenderFragment RenderStatusBadge(ServiceStatus status) => __builder =>
    {
        // กำหนดสีและไอคอนตามสถานะโดยใช้ Switch Expression (C# 8.0+)
        var (color, icon) = status switch
        {
            ServiceStatus.Online => ("bg-green-500", "fa-check"),
            ServiceStatus.Maintenance => ("bg-orange-500", "fa-screwdriver-wrench"),
            _ => ("bg-slate-400", "fa-question")
        };

        <div class="flex items-center justify-center h-8 w-8 rounded-full border-2 border-white @color shadow-md">
            <i class="fa-solid @icon text-[12px] text-white"></i>
        </div>
    };

