    // ฟังก์ชันเปิด Modal สำหรับเพิ่มใหม่
    private void OpenAddModal()
    {
        isEditMode = false; // บอกระบบว่านี่คือการ "เพิ่มใหม่"
        isShowCustomPicker = false;
        editingService = new ServiceItem
        {
            Title = "",
            Description = "",
            IconClass = "fa-solid fa-star", // ค่าเริ่มต้น
            TargetUrl = "",
            GradientStyle = "from-gray-400 to-gray-300"
        };
        modalTitle = "เพิ่มบริการใหม่";
        isModalOpen = true;
    }

    // ฟังก์ชันเปิด Modal สำหรับแก้ไข
    private void OpenEditModal(ServiceItem service)
    {
        isEditMode = true; // บอกระบบว่านี่คือการ "แก้ไข"
        isShowCustomPicker = false;
        originalService = service;
        editingService = new ServiceItem
        {
            Title = service.Title,
            Description = service.Description,
            IconClass = service.IconClass,
            TargetUrl = service.TargetUrl,
            GradientStyle = service.GradientStyle,
            Status = service.Status
        };
        modalTitle = "แก้ไขข้อมูลบริการ";
        isModalOpen = true;
    }

    private void CloseModal() => isModalOpen = false;

    private void HandleSave()
    {
        if (editingService == null) return;

        // ถ้าแอดมินเปิดหน้าต่าง Custom Picker ทิ้งไว้ ให้ดึงสีจาก Color Picker มาใช้ทันที
        if (isShowCustomPicker)
        {
            editingService.GradientStyle = $"from-[{customFrom}] to-[{customTo}]";
        }

        if (isEditMode && originalService != null)
        {
            // เอาข้อมูลจาก "ตัวก๊อปปี้" (editingService) ไปทับ "ตัวจริง" (originalService)
            originalService.Title = editingService.Title;
            originalService.Description = editingService.Description;
            originalService.IconClass = editingService.IconClass;
            originalService.TargetUrl = editingService.TargetUrl;
            originalService.GradientStyle = editingService.GradientStyle;
            originalService.Status = editingService.Status;
        }
        else
        {
            // นำ "ตัวก๊อปปี้" ที่เรากรอกข้อมูลไว้ เพิ่มเข้าไปใน List หลัก
            _services.Add(editingService);
        }
        
        // หมายเหตุ: ถ้าเป็นโหมดแก้ไข (isEditMode = true)
        // ข้อมูลใน List จะถูกอัปเดตอัตโนมัติผ่าน @bind อยู่แล้ว
        isModalOpen = false; // ปิดหน้าต่าง
        // สั่งให้ Blazor วาดหน้าจอใหม่เพื่อให้เห็นข้อมูลที่เปลี่ยนไป
        StateHasChanged();
    }

    private async Task HandleDelete(ServiceItem service)
    {
        // แสดงหน้าต่างยืนยันเพื่อป้องกันการกดพลาด
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"คุณแน่ใจหรือไม่ว่าต้องการลบบริการ '{service.Title}'?");

        if (confirmed)
        {
            _services.Remove(service);

            toastMessage = $"ลบบริการ '{service.Title}' สำเร็จแล้ว";
            showToast = true;
            StateHasChanged();

            await Task.Delay(3000);
            showToast = false;
            StateHasChanged();
        }
    }

    private void ToggleCustomPicker()
    {
        isShowCustomPicker = !isShowCustomPicker;
    }

